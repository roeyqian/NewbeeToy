import { Button, LineEdit } from "std-widgets.slint";

export struct UnlockPreviewRow {
    process_name: string,
    process_id: string,
    process_kind: string,
    file_kind: string,
    note: string,
    has_warning: bool,
}

export component UnlockPanel inherits VerticalLayout {
    in property <brush> panel_background;
    in-out property <string> target_path;
    in-out property <string> status_text;
    in-out property <string> preview_text;
    in-out property <[UnlockPreviewRow]> preview_rows;
    in-out property <bool> lang_en;
    pure callback tr(string, bool) -> string;

    callback pick_target_file(string) -> string;
    callback pick_target_folder(string) -> string;
    callback scan_request(string);
    callback release_request();
    callback remove_row_request(int);
    callback clear_request();

    spacing: 8px;

    HorizontalLayout {
        spacing: 8px;
        Text {
            text: root.tr("unlock.target_label", root.lang_en);
            vertical-alignment: center;
        }
        LineEdit {
            text <=> root.target_path;
            min-width: 220px;
            horizontal-stretch: 1;
        }
        Button {
            text: root.tr("unlock.browse_folder", root.lang_en);
            min-width: 96px;
            clicked => {
                let selected = root.pick_target_folder(root.target_path);
                if (selected != "") {
                    root.target_path = selected;
                }
            }
            vertical-stretch: 0;
        }
        Button {
            text: root.tr("unlock.browse", root.lang_en);
            min-width: 96px;
            clicked => {
                let selected = root.pick_target_file(root.target_path);
                if (selected != "") {
                    root.target_path = selected;
                }
            }
            vertical-stretch: 0;
        }
    }

    HorizontalLayout {
        spacing: 8px;
        Button {
            text: root.tr("unlock.scan", root.lang_en);
            min-width: 96px;
            horizontal-stretch: 1;
            clicked => {
                root.scan_request(root.target_path);
            }
            vertical-stretch: 0;
        }
        Button {
            text: root.tr("unlock.release", root.lang_en);
            min-width: 96px;
            horizontal-stretch: 1;
            clicked => {
                root.release_request();
            }
            vertical-stretch: 0;
        }
        Button {
            text: root.tr("unlock.clear", root.lang_en);
            min-width: 96px;
            horizontal-stretch: 1;
            clicked => {
                root.clear_request();
            }
            vertical-stretch: 0;
        }
    }

    Text { text: root.tr("unlock.log", root.lang_en); }
    Rectangle {
        border-width: 1px;
        border-color: #b7bec7;
        background: root.panel_background;
        vertical-stretch: 3;

        Flickable {
            x: 1px;
            y: 1px;
            width: parent.width - 2px;
            height: parent.height - 2px;
            viewport-width: self.width;
            viewport-height: status_body.preferred-height + 16px;
            viewport-y: self.viewport-height > self.height ? self.height - self.viewport-height : 0px;

            status_body := Text {
                text: root.status_text;
                x: 8px;
                y: 8px;
                width: parent.width - 16px;
                wrap: char-wrap;
            }
        }
    }

    Text { text: root.tr("unlock.preview_title", root.lang_en); }
    Rectangle {
        border-width: 1px;
        border-color: #c2cad4;
        background: root.panel_background;
        clip: true;
        vertical-stretch: 7;

        if (root.preview_text != ""): Flickable {
            x: 1px;
            y: 1px;
            width: parent.width - 2px;
            height: parent.height - 2px;
            viewport-width: self.width;
            viewport-height: preview_message.preferred-height + 16px;

            preview_message := Text {
                text: root.preview_text;
                x: 8px;
                y: 8px;
                width: parent.width - 16px;
                wrap: char-wrap;
                color: #ff6b6b;
            }
        }

        if (root.preview_text == ""): Flickable {
            x: 1px;
            y: 1px;
            width: parent.width - 2px;
            height: parent.height - 2px;
            viewport-width: self.width;
            viewport-height: preview_table.preferred-height + 8px;

            preview_table := VerticalLayout {
                x: 0px;
                y: 0px;
                width: parent.width;
                spacing: 2px;

                Rectangle {
                    width: parent.width;
                    min-height: 28px;
                    background: root.panel_background;

                    HorizontalLayout {
                        spacing: 8px;
                        padding-left: 8px;
                        padding-right: 8px;
                        Rectangle {
                            horizontal-stretch: 1;
                            clip: true;
                            Text {
                                text: root.tr("unlock.table.process", root.lang_en);
                                width: parent.width;
                                vertical-alignment: center;
                                wrap: no-wrap;
                                overflow: elide;
                            }
                        }
                        Text {
                            text: root.tr("unlock.table.pid", root.lang_en);
                            width: 90px;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        Text {
                            text: root.tr("unlock.table.process_kind", root.lang_en);
                            width: 140px;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        Text {
                            text: root.tr("unlock.table.file_kind", root.lang_en);
                            width: 110px;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        Text {
                            text: root.tr("unlock.table.note", root.lang_en);
                            width: 180px;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        Text {
                            text: "";
                            width: 68px;
                        }
                    }
                }

                for row[i] in root.preview_rows : Rectangle {
                    width: parent.width;
                    min-height: 28px;
                    background: root.panel_background;

                    HorizontalLayout {
                        spacing: 8px;
                        padding-left: 8px;
                        padding-right: 8px;
                        Rectangle {
                            horizontal-stretch: 1;
                            clip: true;
                            Text {
                                text: row.process_name;
                                width: parent.width;
                                vertical-alignment: center;
                                wrap: no-wrap;
                                overflow: elide;
                            }
                        }
                        Text {
                            text: row.process_id;
                            width: 90px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: row.process_kind;
                            width: 140px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: row.file_kind;
                            width: 110px;
                            vertical-alignment: center;
                        }
                        if (row.has_warning): Text {
                            text: row.note;
                            width: 180px;
                            vertical-alignment: center;
                            color: #ff6b6b;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        if (!row.has_warning): Text {
                            text: row.note;
                            width: 180px;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        Button {
                            text: root.tr("common.remove", root.lang_en);
                            min-width: 68px;
                            clicked => {
                                root.remove_row_request(i);
                            }
                            vertical-stretch: 0;
                        }
                    }
                }
            }
        }
    }
}

