import { Button, LineEdit } from "std-widgets.slint";

export struct EnvPreviewRow {
    name: string,
    value: string,
}

export component EnvPanel inherits VerticalLayout {
    in property <brush> panel_background;
    in-out property <string> value_path;
    in-out property <string> preset_path;
    in-out property <string> variable_name;
    in-out property <string> status_text;
    in-out property <string> preview_text;
    in-out property <[EnvPreviewRow]> preview_rows;
    in-out property <bool> lang_en;
    pure callback tr(string, bool) -> string;

    callback interaction_request();
    callback pick_value_path(string) -> string;
    callback store_request(string, string, string);
    callback load_preset_request(string);
    callback load_system_request();
    callback preview_request(string, string);
    callback remove_row_request(int);
    callback commit_request();

    spacing: 8px;

    HorizontalLayout {
        spacing: 8px;
        Text {
            text: root.tr("env.preset_path_label", root.lang_en);
            vertical-alignment: center;
        }
        LineEdit {
            text <=> root.preset_path;
            horizontal-stretch: 3;
        }
        Button {
            text: root.tr("env.store", root.lang_en);
            min-width: 96px;
            clicked => {
                root.store_request(root.preset_path, root.value_path, root.variable_name);
            }
            vertical-stretch: 0;
        }
        Button {
            text: root.tr("env.load_preset", root.lang_en);
            min-width: 96px;
            clicked => {
                root.load_preset_request(root.preset_path);
            }
            vertical-stretch: 0;
        }
    }

    HorizontalLayout {
        spacing: 8px;
        Text {
            text: root.tr("env.value_path_label", root.lang_en);
            vertical-alignment: center;
        }
        LineEdit {
            text <=> root.value_path;
        }
        Button {
            text: root.tr("env.browse", root.lang_en);
            min-width: 96px;
            clicked => {
                root.interaction_request();
                let selected = root.pick_value_path(root.value_path);
                if (selected != "") {
                    root.value_path = selected;
                }
            }
            vertical-stretch: 0;
        }
    }

    HorizontalLayout {
        spacing: 8px;
        Text {
            text: root.tr("env.variable_name", root.lang_en);
            vertical-alignment: center;
        }
        LineEdit {
            text <=> root.variable_name;
            min-width: 140px;
            horizontal-stretch: 2;
        }
        Button {
            text: root.tr("env.load_system", root.lang_en);
            min-width: 96px;
            horizontal-stretch: 1;
            clicked => {
                root.load_system_request();
            }
            vertical-stretch: 0;
        }
        Button {
            text: root.tr("env.preview", root.lang_en);
            min-width: 96px;
            horizontal-stretch: 1;
            clicked => {
                root.preview_request(root.value_path, root.variable_name);
            }
            vertical-stretch: 0;
        }
        Button {
            text: root.tr("env.apply", root.lang_en);
            min-width: 96px;
            horizontal-stretch: 1;
            clicked => {
                root.commit_request();
            }
            vertical-stretch: 0;
        }
    }

    Text { text: root.tr("env.log", root.lang_en); }
    Rectangle {
        border-width: 1px;
        border-color: #b7bec7;
        background: root.panel_background;
        vertical-stretch: 3;

        Flickable {
            x: 1px;
            y: 1px;
            width: parent.width - 2px;
            height: parent.height - 2px;
            viewport-width: self.width;
            viewport-height: status_body.preferred-height + 16px;
            viewport-y: self.viewport-height > self.height ? self.height - self.viewport-height : 0px;

            status_body := Text {
                text: root.status_text;
                x: 8px;
                y: 8px;
                width: parent.width - 16px;
                wrap: char-wrap;
            }
        }
    }

    Text { text: root.tr("env.preview_title", root.lang_en); }
    Rectangle {
        border-width: 1px;
        border-color: #c2cad4;
        background: root.panel_background;
        clip: true;
        vertical-stretch: 7;

        if (root.preview_text != ""): Flickable {
            x: 1px;
            y: 1px;
            width: parent.width - 2px;
            height: parent.height - 2px;
            viewport-width: self.width;
            viewport-height: preview_message.preferred-height + 16px;

            preview_message := Text {
                text: root.preview_text;
                x: 8px;
                y: 8px;
                width: parent.width - 16px;
                wrap: char-wrap;
                color: #ff6b6b;
            }
        }

        if (root.preview_text == ""): Flickable {
            x: 1px;
            y: 1px;
            width: parent.width - 2px;
            height: parent.height - 2px;
            viewport-width: self.width;
            viewport-height: preview_table.preferred-height + 8px;

            preview_table := VerticalLayout {
                x: 0px;
                y: 0px;
                width: parent.width;
                spacing: 2px;

                Rectangle {
                    width: parent.width;
                    min-height: 28px;
                    background: root.panel_background;

                    HorizontalLayout {
                        spacing: 8px;
                        padding-left: 8px;
                        padding-right: 8px;
                        Text {
                            text: "";
                            width: 68px;
                        }
                        Text {
                            text: root.tr("env.table.name", root.lang_en);
                            width: 220px;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        Rectangle {
                            horizontal-stretch: 1;
                            clip: true;
                            Text {
                                text: root.tr("env.table.value", root.lang_en);
                                width: parent.width;
                                vertical-alignment: center;
                                wrap: no-wrap;
                                overflow: elide;
                            }
                        }
                    }
                }

                for row[i] in root.preview_rows : Rectangle {
                    width: parent.width;
                    min-height: 28px;
                    background: root.panel_background;

                    HorizontalLayout {
                        spacing: 8px;
                        padding-left: 8px;
                        padding-right: 8px;
                        Button {
                            text: root.tr("common.remove", root.lang_en);
                            min-width: 68px;
                            clicked => {
                                root.remove_row_request(i);
                            }
                            vertical-stretch: 0;
                        }
                        Text {
                            text: row.name;
                            width: 220px;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        Rectangle {
                            horizontal-stretch: 1;
                            clip: true;
                            Text {
                                text: row.value;
                                width: parent.width;
                                vertical-alignment: center;
                                wrap: no-wrap;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }
    }
}

